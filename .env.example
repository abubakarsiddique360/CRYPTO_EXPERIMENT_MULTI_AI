# Copy to .env (do not commit .env)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# Optional: override model IDs (recommended if a provider changes names)
DEEPSEEK_MODEL=deepseek-chat
CHATGPT_MODEL=gpt-5-mini

# OpenAI API style (recommended for GPT-5 family)
OPENAI_API_STYLE=responses
GEMINI_MODEL=
GROK_MODEL=

# Optional: OpenAI networking knobs (useful on Windows / corporate networks)
# If you are behind a corporate proxy, set this or HTTPS_PROXY.
OPENAI_PROXY=
# Whether to honor HTTPS_PROXY/HTTP_PROXY env vars (set to 1 if you need system proxy)
OPENAI_TRUST_ENV=0
# Force IPv4 (can help when IPv6 routing is broken)
OPENAI_FORCE_IPV4=1
# OpenAI connect timeout (seconds)
OPENAI_CONNECT_TIMEOUT=20
# OpenAI total timeout (seconds) - cryptanalysis can be slow
OPENAI_TIMEOUT=300
# Max output tokens for Responses API (gpt-5*)
OPENAI_MAX_OUTPUT_TOKENS=800
# Max output tokens for legacy chat_completions
OPENAI_MAX_COMPLETION_TOKENS=4000

# Optional: rate limits (RPM). Many OpenAI trial keys are 3 RPM.
OPENAI_REQUESTS_PER_MINUTE=3

# Optional: global request settings
MAX_RETRIES=3
TIMEOUT=45


# Optional: output caps for Gemini/Grok
GEMINI_MAX_OUTPUT_TOKENS=800
GROK_MAX_TOKENS=800

